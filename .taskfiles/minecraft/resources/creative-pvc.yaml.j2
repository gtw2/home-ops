---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: minecraft-{{ ENV.SOURCE }}-creative
  namespace: {{ ENV.NAMESPACE }}
  labels:
    # Match the labels the bjw-s app-template applies to the creative HR's resources,
    # so the PVC groups consistently with the Deployment/Pod that mounts it.
    app.kubernetes.io/name: minecraft-{{ ENV.SOURCE }}-creative
    app.kubernetes.io/instance: minecraft-{{ ENV.SOURCE }}-creative
    app.kubernetes.io/component: creative-clone
spec:
  accessModes:
    - ReadWriteOnce
  storageClassName: ceph-block
  resources:
    requests:
      storage: {{ ENV.SIZE }}
  dataSource:
    apiGroup: ""
    kind: PersistentVolumeClaim
    name: minecraft-{{ ENV.SOURCE }}
